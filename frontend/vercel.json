{
  "redirects": [
    {
      "source": "/biizzed/:path*",
      "has": [{ "type": "host", "value": "biizzed.lovohcreate.com" }],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/uduua/:path*",
      "has": [{ "type": "host", "value": "uduua.lovohcreate.com" }],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/events/:path*",
      "has": [{ "type": "host", "value": "event-room.lovohcreate.com" }],
      "destination": "/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/og/event/:id", "destination": "/api/og-event.js" },
    { "source": "/api/og/biizzed/article/:slug", "destination": "/api/og-biizzed-article.js" },
    { "source": "/api/og/biizzed/magazine/:id", "destination": "/api/og-biizzed-magazine.js" },
    { "source": "/api/og/biizzed/video/:id", "destination": "/api/og-biizzed-video.js" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
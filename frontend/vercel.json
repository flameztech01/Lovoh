{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "uduua.lovohcreate.com"
        }
      ],
      "destination": "/uduua/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "biizzed.lovohcreate.com"
        }
      ],
      "destination": "/biizzed/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "event-room.lovohcreate.com"
        }
      ],
      "destination": "/events/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
{
  "rewrites": [
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/:path*.js", "destination": "/:path*.js" },
    { "source": "/:path*.css", "destination": "/:path*.css" },
    { "source": "/:path*.svg", "destination": "/:path*.svg" },
    { "source": "/:path*.png", "destination": "/:path*.png" },
    { "source": "/:path*.jpg", "destination": "/:path*.jpg" },
    { "source": "/:path*.jpeg", "destination": "/:path*.jpeg" },
    { "source": "/:path*.gif", "destination": "/:path*.gif" },
    { "source": "/:path*.ico", "destination": "/:path*.ico" },
    { "source": "/:path*.woff", "destination": "/:path*.woff" },
    { "source": "/:path*.woff2", "destination": "/:path*.woff2" },
    { "source": "/:path*.ttf", "destination": "/:path*.ttf" },
    { "source": "/:path*.eot", "destination": "/:path*.eot" },
    { "source": "/:path*.xml", "destination": "/:path*.xml" },
    { "source": "/:path*.txt", "destination": "/:path*.txt" },
    { "source": "/:path*.map", "destination": "/:path*.map" },
    { "source": "/:path*.webmanifest", "destination": "/:path*.webmanifest" },
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/api/og" }
  ]
}